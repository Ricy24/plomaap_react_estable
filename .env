# Backend
VITE_API_URL=http://localhost:5000

# Cloudinary (Almacenamiento de imágenes - 25GB gratis)
# Regístrate en https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=tu_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=tu_upload_preset

# Google OAuth 2.0
# Obtén credenciales en https://console.cloud.google.com
VITE_GOOGLE_CLIENT_ID=tu_google_client_id

# Notas:
# 1. CLOUDINARY_CLOUD_NAME: Lo encuentras en tu dashboard de Cloudinary
# 2. CLOUDINARY_UPLOAD_PRESET: Crea uno en Cloudinary Settings > Upload
# 3. GOOGLE_CLIENT_ID: Lo tienes en Google Cloud Console
