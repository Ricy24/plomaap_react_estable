# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
FLASK_PORT=5000
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# MySQL Database
MYSQL_USER=root
MYSQL_PASSWORD=
